generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. 일기 작성 시 본인이 선택하는 감정 (8종)
enum EmotionType {
  ABSURD // 황당
  ANGRY // 화남
  BLANK // 무념무상
  DEPRESSED // 우울
  DISGUSTED // 짜증
  EXCITED // 설렘
  TIRED // 지침
  HAPPY // 기쁨
}

// 2. 사용자 모델
model Member {
  id        BigInt   @id @default(autoincrement())
  email     String   @unique @db.VarChar(50)
  nickname  String   @unique @db.VarChar(8)
  password  String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  diaries        Diary[]
  empathyRecords EmpathyRecord[]

  @@map("member")
}

// 3. 표준 질문
model StandardQuestion {
  id      BigInt  @id @default(autoincrement())
  content String  @db.Text
  diaries Diary[]

  @@map("standard_question")
}

// 4. 일기 모델
model Diary {
  id        BigInt   @id @default(autoincrement())
  title     String   @db.VarChar(30)
  content   String   @db.Text
  diaryDate DateTime @map("diary_date") @db.Date

  emotion EmotionType // 8종 Enum 사용

  isEdited  Boolean  @default(false) @map("is_edited")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberId   BigInt @map("member_id")
  questionId BigInt @map("question_id")

  member           Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  standardQuestion StandardQuestion @relation(fields: [questionId], references: [id])
  photos           DiaryPhoto[]
  squarePost       SquarePost?

  @@unique([memberId, diaryDate])
  @@unique([memberId, questionId])
  @@map("diary")
}

// 5. 일기 사진
model DiaryPhoto {
  id           BigInt @id @default(autoincrement())
  imageUrl     String @map("image_url") @db.Text
  displayOrder Int    @default(0) @map("display_order")
  diaryId      BigInt @map("diary_id")

  diary Diary @relation(fields: [diaryId], references: [id], onDelete: Cascade)

  @@map("diary_photo")
}

// 6. 광장 게시물
model SquarePost {
  id        BigInt   @id @default(autoincrement())
  isActive  Boolean  @default(true) @map("is_active")
  diaryId   BigInt   @unique @map("diary_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  diary          Diary           @relation(fields: [diaryId], references: [id], onDelete: Cascade)
  empathyRecords EmpathyRecord[]

  @@map("square_post")
}

// 7. 공감 종류 (5종 리액션 마스터 테이블)
model EmpathyType {
  id             BigInt          @id @default(autoincrement())
  name           String          @db.VarChar(20) // "설렘", "신남" 등
  empathyRecords EmpathyRecord[]

  @@map("empathy_type")
}

// 8. 공감 기록 (유저가 게시글에 남긴 실제 데이터)
model EmpathyRecord {
  id        BigInt   @id @default(autoincrement())
  memberId  BigInt   @map("member_id")
  postId    BigInt   @map("post_id")
  typeId    BigInt   @map("type_id")
  createdAt DateTime @default(now()) @map("created_at")

  member      Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  squarePost  SquarePost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  empathyType EmpathyType @relation(fields: [typeId], references: [id])

  @@unique([memberId, postId])
  @@map("empathy_record")
}
